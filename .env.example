# JWT - use a long, random string in production
JWT_SECRET=change-this-to-a-long-random-secret-before-production

# Admin seed account (used only on first run if no admin exists)
ADMIN_EMAIL=admin@medtrace.com
ADMIN_PASSWORD=Admin@MedTrace2024!

# Gemini AI (optional - enables AI insights in admin dashboard)
GEMINI_API_KEY=

# App
NODE_ENV=development
PORT=3000
